// This is a two-pass fragment shader designed to create a dynamic Mouse Trail / Liquid Ripple effect. It works by using a "ping-pong" texture setup:Pass 1 (History/Draw Pass - Index 1): Captures mouse movement, encodes the direction of movement into a color (HSV/Hue), and slowly blurs/fades the previous frame's color data. This texture stores the velocity field (direction $\rightarrow$ Hue, speed $\rightarrow$ Value).Pass 2 (Render Pass - Index 0): Uses the color (velocity) data from Pass 1 to distort the main input texture (uTexture), creating the liquid or ripple effect.1. Vertex Shaders (Shared)The fragment shaders use two slightly different vertex shaders, likely depending on whether the output needs to interact with a specific transformation matrix (uTextureMatrix).Vertex Shader (Pass 0 - Render Pass)
// OpenGL Shading Language
#version 300 es
precision mediump float;

in vec3 aVertexPosition;
in vec2 aTextureCoord;

uniform mat4 uMVMatrix;
uniform mat4 uPMatrix;

out vec2 vTextureCoord;
out vec3 vVertexPosition;

void main() {
    gl_Position = uPMatrix * uMVMatrix * vec4(aVertexPosition, 1.0);
    vTextureCoord = aTextureCoord;
}
// Vertex Shader (Pass 1 - History/Draw Pass)
// OpenGL Shading Language
#version 300 es
precision mediump float;

in vec3 aVertexPosition;
in vec2 aTextureCoord;

uniform mat4 uMVMatrix;
uniform mat4 uPMatrix;
uniform mat4 uTextureMatrix;

out vec2 vTextureCoord;
out vec3 vVertexPosition;

void main() {
    gl_Position = uPMatrix * uMVMatrix * vec4(aVertexPosition, 1.0);
    vTextureCoord = (uTextureMatrix * vec4(aTextureCoord, 0.0, 1.0)).xy;
}

// 2. Fragment Shader Pass 1: History/Draw (Writes Velocity Field)This pass handles the drawing of the mouse path into the uPingPongTexture. The color encodes the angle of movement.
// OpenGL Shading Language
#version 300 es
precision highp float;

in vec3 vVertexPosition;
in vec2 vTextureCoord;

// Uniforms
uniform sampler2D uPingPongTexture; // Previous frame's velocity data
uniform vec2 uPreviousMousePos;
uniform vec2 uMousePos;
uniform vec2 uResolution;

out vec4 fragColor;

const float PI = 3.1415926;
const float TWOPI = 6.2831852;

// --- Utility Function ---

// HSV to RGB conversion
vec3 hsv2rgb(vec3 c) {
    vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
    vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
    return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
}

void main() {
    float aspectRatio = uResolution.x / uResolution.y;
    vec2 aspectVec = vec2(aspectRatio, 1.0);
    vec2 uv = vTextureCoord;
    vec2 correctedUv = uv * aspectVec; // UV corrected for aspect ratio

    // 1. Calculate Mouse Movement Direction and Distance
    vec2 dir = (uMousePos - uPreviousMousePos) * aspectVec;
    float dist = length(dir);

    if (dist > 0.0) {
        dir = dir / dist; // Normalized direction vector
    } else {
        dir = vec2(1.0, 0.0);
    }

    // 2. Encode Direction as Hue
    float angle = atan(dir.y, dir.x);
    if (angle < 0.0) angle += TWOPI;
    
    // Mouse color is HSV(angle/TWOPI, 1.0, 1.0) -> Hue=Angle, Saturation/Value=1.0
    vec3 color = vec3(angle / TWOPI, 1.0, 1.0);
    vec3 mouseColor = hsv2rgb(color);

    // 3. Draw Line Segment (Anti-aliased Line)
    
    // Find closest point 'closestPoint' on the line segment between previous and current mouse pos
    // 't' is the parameter along the line segment [0.0, 1.0]
    float t = dist > 0.0 ? clamp(dot(correctedUv - uPreviousMousePos * aspectVec, dir) / dist, 0.0, 1.0) : 0.0;
    vec2 closestPoint = mix(uPreviousMousePos, uMousePos, t) * aspectVec;
    float distanceToLine = distance(correctedUv, closestPoint);

    // Dynamic Radius ('rad') based on a fixed size (0.64 * 0.4)
    float rad = 0.6400 * 0.4 * mix(aspectRatio, 1.0, 0.5); 
    
    // Shrink radius based on speed (dist)
    float shrink = mix(0.5, 1.0, clamp(dist * 20.0, 0.0, 1.0));
    rad *= shrink;
    
    // Anti-aliased line mask 's' (squared smoothstep for sharper edge)
    float s = smoothstep(rad, rad * 0.0000, distanceToLine); // Note: rad * 0.0000 creates a hard edge, not smooth
    s = s * s; 
    
    // 4. Decay and Blur Previous Frame (History)
    
    // Sample texture with slight blur (Box Blur) and decay (0.4)
    float blurRadius = 0.003;
    vec3 lastFrameColor = texture(uPingPongTexture, uv).rgb * 0.4;
    lastFrameColor += texture(uPingPongTexture, uv + vec2(blurRadius, 0.0)).rgb * 0.15;
    lastFrameColor += texture(uPingPongTexture, uv + vec2(-blurRadius, 0.0)).rgb * 0.15;
    lastFrameColor += texture(uPingPongTexture, uv + vec2(0.0, blurRadius)).rgb * 0.15;
    lastFrameColor += texture(uPingPongTexture, uv + vec2(0.0, -blurRadius)).rgb * 0.15;
    
    // Linearize colors (gamma correction)
    lastFrameColor = pow(lastFrameColor, vec3(2.2));
    mouseColor = pow(mouseColor, vec3(2.2));
    
    // Additional decay factor (0.5000^0.2)
    lastFrameColor *= pow(0.5000, 0.2); 
    
    // 5. Composite: Blend decay and new mouse input
    
    // 'clampedDist' determines blend strength (based on mouse speed 'dist' and line mask 's')
    float clampedDist = clamp(min(1.0, dist * 10.0) * s, 0.0, 1.0); 
    vec3 draw = mix(lastFrameColor, mouseColor, clampedDist);

    // Apply gamma (sRGB)
    draw = pow(draw, vec3(1.0/2.2));
    fragColor = vec4(draw, 1.0);
}


// 3. Fragment Shader Pass 0: Render (Applies Distortion)This pass uses the velocity field (Pass 1's output, stored in uPingPongTexture) to distort the main scene texture (uTexture).
// OpenGL Shading Language
#version 300 es
precision highp float;

in vec2 vTextureCoord;
in vec3 vVertexPosition;

// Uniforms
uniform sampler2D uTexture;         // Main scene texture
uniform sampler2D uPingPongTexture; // Velocity/History texture (Output of Pass 1)
uniform vec2 uResolution;

out vec4 fragColor;

const float PI = 3.1415926;
const float ITERATIONS = 24.0;

// --- Utility Functions ---

// RGB to HSV conversion
vec3 rgb2hsv(vec3 c) {
    vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
    vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
    vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
    float d = q.x - min(q.w, q.y);
    float e = 1.0e-10;
    // q.z is Hue (H), d/(q.x+e) is Saturation (S), q.x is Value (V)
    return vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
}

// Simple Chromatic Aberration (R sampled left, B sampled right)
vec3 chromatic_aberration(vec3 color, vec2 uv, vec2 offset) {
    vec4 left = texture(uTexture, uv - offset);
    vec4 right = texture(uTexture, uv + offset);
    color.r = left.r;
    color.b = right.b;
    return color;
}

// Converts a normalized angle (0-1) to a 2D direction vector
vec2 angleToDir(float angle) {
    float rad = angle * 2.0 * PI;
    return vec2(cos(rad), sin(rad));
}

// --- Distortion Logic ---

vec4 defaultTrail(vec2 uv, vec2 mouseDir) {
    // 1. Distort UV based on the velocity field (`mouseDir`)
    vec2 distorted = mouseDir * 0.4;
    uv -= distorted;
    
    // 2. Sample original texture at the distorted UV
    vec4 color = texture(uTexture, uv);
    
    // 3. Apply Chromatic Aberration in the direction of distortion
    color.rgb = chromatic_aberration(color.rgb, uv, distorted * 0.2500 * 0.12);
    
    return color;
}

// Gets the final distorted color
vec4 getTrailColor(vec2 uv, vec2 mouseDir, float strength, float aspectRatio) {
    vec4 color = vec4(0);
    return defaultTrail(uv, mouseDir);
}

void main() {
    vec2 uv = vTextureCoord;
    vec2 pingpongUv = uv;
    float aspectRatio = uResolution.x / uResolution.y;
    
    // 1. Read Velocity Field Data from Pass 1 output
    vec3 mouseRgb = texture(uPingPongTexture, pingpongUv).rgb;
    vec3 mouseTrail = rgb2hsv(mouseRgb);
    
    // Decode HSV data:
    float angle = mouseTrail.x; // H (Hue) -> Angle (0-1)
    float strength = mouseTrail.z * (0.5000 * 1.5); // V (Value) -> Strength/Speed
    
    // 2. Convert angle and strength to a 2D distortion vector
    vec2 direction = angleToDir(angle);
    vec2 mouseDir = direction * strength;
    
    // 3. Apply Distortion
    vec4 color = getTrailColor(uv, mouseDir, abs(strength), aspectRatio);
    
    fragColor = color;
}

