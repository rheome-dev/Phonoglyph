// This multi-pass shader is designed to create a Reflective Surface effect, typically resembling a floor or water reflection. It combines a two-pass Gaussian blur (the "reflection blur") with a final compositing pass that samples the original texture, flips it vertically, and blends it based on the screen's vertical position.

// The three fragment shaders (0, 1, and 2) represent the two stages of the separable Gaussian blur and the final composition pass, respectively.

// 1. Vertex Shader (Shared)
// OpenGL Shading Language

#version 300 es
precision mediump float;

// Attributes
in vec3 aVertexPosition;
in vec2 aTextureCoord;

// Uniforms
uniform mat4 uMVMatrix;
uniform mat4 uPMatrix;
uniform mat4 uTextureMatrix;

// Outputs
out vec2 vTextureCoord;
out vec3 vVertexPosition;

void main() {
    gl_Position = uPMatrix * uMVMatrix * vec4(aVertexPosition, 1.0);
    vTextureCoord = (uTextureMatrix * vec4(aTextureCoord, 0.0, 1.0)).xy;
}

// 2. Fragment Shaders (Blur and Composite)
// Shared Utility Functions
// These functions are present in all three passes, handling coordinate rotation, Gaussian weights, and the Gaussian blur operation itself.
// OpenGL Shading Language


const float PI2 = 6.28318530718;

// Rotates a point around a center by an angle
vec2 rotatePoint(vec2 point, vec2 center, float angle) {
    vec2 translated = point - center;
    float cosAngle = cos(angle);
    float sinAngle = sin(angle);
    vec2 rotated = vec2(
        translated.x * cosAngle - translated.y * sinAngle,
        translated.x * sinAngle + translated.y * cosAngle
    );
    return rotated + center;
}

// Applies rotation to the UV coordinate, correcting for aspect ratio
vec2 getRotatedCoord(vec2 coord) {
    float aspectRatio = uResolution.x / uResolution.y;
    vec2 correctedCoord = coord;
    correctedCoord.x *= aspectRatio;
    vec2 correctedPos = vec2(0.5, 0.5);
    correctedPos.x *= aspectRatio;
    // Rotation is disabled: 0.0000 * PI2 = 0
    vec2 rotatedCorrected = rotatePoint(correctedCoord, correctedPos, 0.0000 * PI2);
    vec2 result = rotatedCorrected;
    result.x /= aspectRatio;
    return result;
}

// Applies inverse rotation
vec2 getInverseRotatedCoord(vec2 coord) {
    // Logic is the same as getRotatedCoord but with negative angle
    // (Rotation is disabled: 0.0000 * -1. * PI2 = 0)
    // ...
    return result;
}

// Pre-calculated Gaussian weights for a 36-tap kernel
const int kernelSize = 36;
float getGaussianWeight(int index) {
    // ... [switch statement with Gaussian weights 0-35] ...
    // Note: The Gaussian curve is symmetric around index 17/18.
    switch(index) {
        case 0: return 0.00094768;
        // ... (truncated)
        default: return 0.0;
    }
}

// Gaussian Blur (single dimension)
vec4 GaussianBlur(sampler2D tex, vec2 uv, vec2 direction) {
    vec4 color = vec4(0.0);
    
    // Calculate blur radius based on distance from the vertical center
    vec2 rotatedUV = getRotatedCoord(uv);
    vec2 rotatedPos = vec2(0.5, 0.5);
    float y = max(0., distance(rotatedUV.y, rotatedPos.y));
    float radius = 8.;
    
    // Amount determines the actual pixel spread; stronger further from the center line
    float amount = max(0.25, (0.5000 + 0.1) * radius * y * 4.); 
    
    // Adjust direction X for aspect ratio
    float aspectRatio = uResolution.x / uResolution.y;
    direction.x /= aspectRatio;
    
    // Center sample (i=0)
    color += texture(tex, uv) * getGaussianWeight(0);
    
    // Weighted sample loop
    for (int i = 0; i < kernelSize; i++) {
        // x is the sample offset distance
        float x = float(i - kernelSize / 2) * amount;
        // Sample texture using direction vector and offset (x/1000 is a scale factor)
        color += texture(tex, uv + vec2(x/1000.) * direction) * getGaussianWeight(i);
    }
    return color;
}
// Pass 0: Vertical Blur (Implied)
// OpenGL Shading Language

// ... (shared functions above) ...

vec4 blurPass(vec2 uv) {
    float aspectRatio = uResolution.x / uResolution.y;
    vec2 direction = vec2(0);
    
    // Select direction: 0 % 2 == 0 is true, so direction is (0, 1) -> Vertical Blur
    if (0 % 2 == 1) { 
        direction = vec2(1,0);
        direction.x *= (1.-0.5000);
    } else {
        direction = vec2(0,1);
    }
    
    // UV transformation for reflection distortion (mix factor 0.5000 - 0.5 = 0.0, so disabled)
    vec2 rotatedUV = getRotatedCoord(uv);
    vec2 rotatedPos = vec2(0.5, 0.5);
    rotatedUV = mix(rotatedUV, (rotatedUV + vec2(0., rotatedPos.y)) * vec2(1., 0.5), 0.5000 - 0.5);
    uv = getInverseRotatedCoord(rotatedUV);
    
    return GaussianBlur(uTexture, uv, direction);
}

vec4 getColor(vec2 uv) {
    return blurPass(uv);
}

void main() {
    vec2 uv = vTextureCoord;
    vec4 color = getColor(uv);
    fragColor = color; // Output of the first blur pass
}
// Pass 1: Horizontal Blur (Implied)
// OpenGL Shading Language

// ... (shared functions above) ...

vec4 blurPass(vec2 uv) {
    float aspectRatio = uResolution.x / uResolution.y;
    vec2 direction = vec2(0);
    
    // Select direction: 1 % 2 == 1 is true, so direction is (1, 0) -> Horizontal Blur
    if (1 % 2 == 1) { 
        direction = vec2(1,0);
        direction.x *= (1.-0.5000); // Direction X scaled down to 0.5
    } else {
        direction = vec2(0,1);
    }
    
    // ... (UV transformation logic, disabled) ...
    
    return GaussianBlur(uTexture, uv, direction);
}

vec4 getColor(vec2 uv) {
    return blurPass(uv);
}

void main() {
    vec2 uv = vTextureCoord;
    vec4 color = getColor(uv);
    fragColor = color; // Output of the second blur pass (fully blurred reflection)
}
// Pass 2: Final Reflection and Composite
// This pass includes dither and the core reflection logic, using the texture from the first two passes as the blurred reflection source (or the original texture if the blur passes are skipped).

// OpenGL Shading Language

#version 300 es
precision mediump float;

// Inputs
in vec3 vVertexPosition;
in vec2 vTextureCoord;

// Uniforms
uniform sampler2D uTexture;     // The blurred reflection texture (from Pass 1)
uniform sampler2D uBgTexture;   // The original background / scene texture
uniform vec2 uResolution;

// Output
out vec4 fragColor;

// ... (shared PCG hash and Gaussian functions) ...

// Core Reflection and Mix Function
// Note: It ignores 'blurredColor' and uses 'uTexture', which should contain the blurred result.
vec4 reflectAndMix(vec4 originalColor, vec4 blurredColor, float yPos) {
    vec2 rotatedCoord = getRotatedCoord(vTextureCoord);
    
    // 1. Calculate the reflected Y coordinate
    float reflectedY = yPos - (rotatedCoord.y - yPos); // yPos - distance_from_yPos
    reflectedY = clamp(reflectedY, 0., 1.);
    
    // 2. Create the reflected coordinate and convert back
    vec2 rotatedReflectedCoord = vec2(rotatedCoord.x, reflectedY);
    vec2 reflectedCoord = getInverseRotatedCoord(rotatedReflectedCoord);
    reflectedCoord = clamp(reflectedCoord, 0., 1.);
    
    // 3. Sample the reflected color (from uTexture, which holds the blurred result)
    vec4 reflectedColor = texture(uTexture, reflectedCoord);
    
    // 4. Darken the reflected color (0.5000 mix factor)
    reflectedColor.rgb = mix(vec3(0, 0, 0), reflectedColor.rgb, 0.5000);
    
    // 5. Add Dither
    float dither = (randFibo(gl_FragCoord.xy) - 0.5) / 255.0;
    reflectedColor.rgb += dither;
    
    // 6. Blend: Use the original color (uBgTexture) above the yPos line
    // and the reflected color below the yPos line (step(rotatedCoord.y, yPos) is 0 below line, 1 above)
    return mix(originalColor, reflectedColor, step(rotatedCoord.y, yPos));
}

vec4 compositePass(vec2 uv) {
    vec4 bg = texture(uBgTexture, uv);
    vec4 blur = blurPass(uv); // Runs one more blur pass (vertical in this setup: 2 % 2 == 0)
    
    // yPos is 0.5 (the reflection line is the center)
    return reflectAndMix(bg, blur, vec2(0.5, 0.5).y); 
}

vec4 getColor(vec2 uv) {
    return compositePass(uv);
}

void main() {
    vec2 uv = vTextureCoord;
    vec4 color = getColor(uv);
    fragColor = color;
}