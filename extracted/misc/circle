// This shader generates a procedural Circular Shape centered on the screen. It is designed to blend a specific color (a magenta/purple tone) with the background texture within the defined circular area, with a smooth falloff.

// 1. Vertex Shader (Shared)
// OpenGL Shading Language

#version 300 es
precision mediump float;

// Attributes
in vec3 aVertexPosition;
in vec2 aTextureCoord;

// Uniforms
uniform mat4 uMVMatrix;
uniform mat4 uPMatrix;
uniform mat4 uTextureMatrix;

// Outputs
out vec2 vTextureCoord;
out vec3 vVertexPosition;

void main() {
    gl_Position = uPMatrix * uMVMatrix * vec4(aVertexPosition, 1.0);
    vTextureCoord = (uTextureMatrix * vec4(aTextureCoord, 0.0, 1.0)).xy;
}

// 2. Fragment Shader (Circle Generation and Blend)
// This pass calculates the distance from the center, applies aspect ratio correction and scaling, and uses the resulting distance to create a smooth circular mask that blends a new color over the background.

// OpenGL Shading Language

#version 300 es
precision highp float;

// Inputs
in vec3 vVertexPosition;
in vec2 vTextureCoord;

// Uniforms
uniform sampler2D uTexture;
uniform vec2 uResolution;

// Output
out vec4 fragColor;

const float TWO_PI = 6.28318530718;

// --- Utility Functions ---

// 2D Rotation Matrix
mat2 rot(float a) {
    return mat2(cos(a), -sin(a), sin(a), cos(a));
}

// Luma (luminance) calculation
float luma(vec3 color) {
    return dot(color, vec3(0.299, 0.587, 0.114));
}

// --- Main Logic ---

void main() {
    vec2 uv = vTextureCoord;
    vec4 bg = texture(uTexture, uv);
    
    // Luminance-based displacement (Disabled: 0.0000 * 0.5 = 0)
    float lum = luma(bg.rgb);
    float displacement = (lum - 0.5) * 0.0000 * 0.5;
    
    // --- Circle Parameters ---
    
    vec2 aspectRatio = vec2(uResolution.x / uResolution.y, 1.0);
    
    // Skew vector (0.5, 0.5) creates an ellipse if rotation/aspect correction is ignored
    // Since aspectRatio correction is applied, it results in an ellipse if aspect ratio is not 1:1.
    vec2 skew = vec2(0.5000, 1.0 - 0.5000); 
    
    // Half radius of the circle (0.25)
    float halfRadius = 0.5000 * 0.5;
    
    // Inner and Outer radii define the smooth falloff transition band
    float innerEdge = halfRadius - 1.0000 * halfRadius * 0.5; // 0.25 - 0.125 = 0.125
    float outerEdge = halfRadius + 1.0000 * halfRadius * 0.5; // 0.25 + 0.125 = 0.375
    
    vec2 pos = vec2(0.5, 0.5); // Center point

    // --- Distance Calculation ---

    // 1. Scale UV and center coordinates by aspect ratio (corrects for non-square screen pixels)
    // 2. Apply rotation (Disabled: 0.0000 * TWO_PI = 0)
    // 3. Apply skew
    vec2 scaledUV = uv * aspectRatio * rot(0.0000 * TWO_PI) * skew;
    vec2 scaledPos = pos * aspectRatio * rot(0.0000 * TWO_PI) * skew;
    
    // Calculate distance from the center
    float radius = distance(scaledUV, scaledPos);
    
    // --- Falloff and Blend ---
    
    // Create the smooth circular mask: 
    // step(inner, outer, radius) returns a value from 0 (inside) to 1 (outside)
    float falloff = smoothstep(innerEdge + displacement, outerEdge + displacement, radius);
    
    // Invert and scale the falloff (1.0 = full color, 0.0 = no color)
    falloff = (1.0 - falloff) * 1.0000;
    
    // Apply the circle color with the falloff mask (not used in final output blend)
    vec3 circle = vec3(0.4, 0.1, 1) * falloff;
    
    // Mix the background color (bg.rgb) with the new circle color (vec3(0.4, 0.1, 1)) using falloff as the blend factor
    circle = mix(bg.rgb, vec3(0.4, 0.1, 1), falloff);
    
    // Final color output
    vec4 color = vec4(circle, max(bg.a, falloff)); // Alpha is determined by the max of background alpha and the circle mask
    
    fragColor = color;
}