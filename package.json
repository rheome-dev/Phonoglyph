{
  "name": "phonoglyph-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MIDI Visualization Platform - Full Stack Application",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun --filter @phonoglyph/web run dev\" \"bun --filter @phonoglyph/api run dev\"",
    "build": "bun --filter @phonoglyph/web run build && bun --filter @phonoglyph/api run build",
    "test": "bun --filter '*' run test",
    "lint": "bun --filter '*' run lint",
    "clean": "bun --filter '*' run clean"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^8.2.2",
    "jsdom": "^26.1.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "meyda": "^5.6.3"
  }
}
